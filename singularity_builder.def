Bootstrap: docker
From: ubuntu:20.04

%environment
    export TZ=Etc/UTC
    export FLASK_APP=app
    export LC_ALL=C.UTF-8

%post
    apt-get -y update
    export TZ=Etc/UTC
    export LC_ALL=C.UTF-8
    
    apt-get install -y dirmngr gnupg apt-transport-https ca-certificates software-properties-common
    apt-get install -y libxml2-dev libssl-dev libcurl4-openssl-dev cmake git

    apt-key adv --keyserver keyserver.ubuntu.com --recv-keys E298A3A825C0D65DFD57CBB651716619E084DAB9
    add-apt-repository 'deb https://cloud.r-project.org/bin/linux/ubuntu focal-cran40/'
    
    apt-get install -y r-base
    apt-get -y update

    apt-get install -y python3-pip python-is-python3
    python3 -m pip install --upgrade pip
    python3 -m pip install --upgrade setuptools
    python3 -m pip install Flask Flask-Session Flask-Login Flask-SQLAlchemy pyyaml
    python3 -m pip install gunicorn oauthlib requests pyOpenSSL
    python3 -m pip install numpy pandas jupyterlab
    python3 -m pip install PyMuPDF

    R -e    "install.packages('yaml', repos='https://cloud.r-project.org/')"
    R -e    "install.packages('ggpubr', repos = 'https://cloud.r-project.org/', dependencies = TRUE)"
    R -e    "install.packages('tidyverse', repos='https://cloud.r-project.org/')"
    R -e    "install.packages('corrplot', repos='https://cloud.r-project.org/')"
    R -e    "install.packages('corrr', repos='https://cloud.r-project.org/')"
    R -e    "install.packages('BiocManager', repos='https://cloud.r-project.org/')"
    R -e    "BiocManager::install(c('BiocParallel', 'TCGAbiolinks', 'HDF5Array', 'affycoretools', 'affyPLM', 'hgu133plus2.db', 'qvalue', 'sva'))"
    R -e    "install.packages('devtools', repos='https://cloud.r-project.org/')"
    R -e    "devtools::install_github('IRkernel/IRkernel')"
    R -e    "IRkernel::installspec()"
    R -e    "devtools::install_github('zhangyuqing/sva-devel')"
