Run web app inside the container (replace xxxx with a unique port):
cd webapp
export FLASK_APP=app
flask run -h 0.0.0.0 -p xxxx --reload

Setup outside the container:
cd webapp
mkdir uploads
virtualenv venv -p $(which python3) 
source ./venv/bin/activate
pip3 install --upgrade pip
pip install -r requirements.txt

Run web app outside the container (replace xxxx with a unique port):
source ./venv/bin/activate
export FLASK_APP=app
flask run -h 0.0.0.0 -p xxxx --reload
